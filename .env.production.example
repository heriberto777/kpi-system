# Plantilla de variables de entorno para PRODUCCION (prod-app).
# Copiar como ".env" DENTRO de ~/apps/kpi-system en el servidor prod-app (NUNCA commitear el
# archivo real con valores reales: .env y .env.production ya estan en .gitignore).
#
# Nombres de variables verificados contra backend/src/config/env.ts - no renombrar sin revisar
# ese archivo, la app simplemente ignora cualquier variable que no coincida exactamente.

NODE_ENV=production
PORT=5000

# Generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR-por-un-secreto-aleatorio-largo
JWT_EXPIRES_IN=3600

ADMIN_USER=admin
# Generar con: npm run hash-password (dentro de backend/), o ejecutar el script equivalente
# contra el password real que va a usar el admin.
ADMIN_PASSWORD_HASH=CAMBIAR-hash-bcrypt-del-password-de-admin

# --- Base de datos analitica (prod-db, SERVIDOR APARTE de prod-app) ---
# IMPORTANTE: prod-db no la levanta este stack (docker-compose.prod.yml no incluye Postgres).
# Debe existir de antemano en prod-db: la base "kpi_analytics" y el usuario/password de abajo,
# con prod-app teniendo salida de red hacia prod-db:5432.
POSTGRES_HOST=CAMBIAR-ip-o-hostname-de-prod-db
POSTGRES_PORT=5432
POSTGRES_DATABASE=kpi_analytics
POSTGRES_USER=CAMBIAR
POSTGRES_PASSWORD=CAMBIAR

# --- ERP MSSQL (CATELLI) ---
# CONFIRMAR: direccion real e IP/puerto alcanzable desde prod-app (no desde tu maquina local).
MSSQL_SERVER=CAMBIAR-ip-del-servidor-mssql-real
MSSQL_PORT=1433
MSSQL_DATABASE=CAMBIAR
MSSQL_USER=CAMBIAR
MSSQL_PASSWORD=CAMBIAR
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true
# Dejar vacias para usar el comportamiento por defecto ("ultimos 60 dias desde hoy").
MSSQL_SYNC_FECHA_DESDE=
MSSQL_SYNC_FECHA_HASTA=

LOG_LEVEL=info
LOG_FORMAT=json

# Con el frontend sirviendo por nginx (Dockerfile.prod) y proxeando /api/ internamente, el
# navegador nunca llama al backend en un origen distinto: CORS_ORIGIN casi no entra en juego,
# pero se deja el dominio real por si se agrega otro cliente en el futuro.
CORS_ORIGIN=https://kpi.ciguadev.com

CRON_ENABLED=true

# Opcional: resumen diario por Telegram. Dejar vacio para desactivarlo.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Solo usadas por docker-compose.prod.yml (no por la app en si) ---
FRONTEND_PORT=8290
