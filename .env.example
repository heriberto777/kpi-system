# Variables usadas por docker-compose.yml
JWT_SECRET=
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true
# Opcional: fija una ventana de fechas para sincronizar ventas (backfills / pruebas).
# Si se dejan vacias, se usa "ultimos 60 dias desde hoy".
MSSQL_SYNC_FECHA_DESDE=
MSSQL_SYNC_FECHA_HASTA=

CRON_ENABLED=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
