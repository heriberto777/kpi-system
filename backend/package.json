{
  "name": "erp-kpi-backend",
  "version": "1.0.0",
  "description": "Backend ETL + APIs REST para KPIs de Ventas y Distribucion - Inversiones Catelli",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "ts-node src/scripts/migrate.ts",
    "migrate:docker": "node dist/scripts/migrate.js",
    "hash-password": "ts-node src/scripts/hash-password.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "3.1.14",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
