# ============================================
# Backend
# ============================================
NODE_ENV=development
PORT=5000
JWT_SECRET=
JWT_EXPIRES_IN=3600

# ============================================
# Usuario administrativo (autenticacion simple)
# ============================================
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# ============================================
# MSSQL ERP (Produccion - solo lectura)
# ============================================
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
# Si el servidor usa un certificado autofirmado (comun en redes internas),
# pon MSSQL_ENCRYPT=true y MSSQL_TRUST_SERVER_CERTIFICATE=true, o la conexion fallara con ESOCKET.
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true
# Opcional: fija una ventana de fechas para sincronizar ventas (backfills / pruebas).
# Si se dejan vacias, se usa "ultimos 60 dias desde hoy".
MSSQL_SYNC_FECHA_DESDE=
MSSQL_SYNC_FECHA_HASTA=

# ============================================
# PostgreSQL Analytics
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=kpi_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Cron Jobs (activar/desactivar en runtime)
# ============================================
CRON_ENABLED=true

# ============================================
# Telegram (opcional)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000
